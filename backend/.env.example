# =============================================================================
# Sistema Legal CO - Variables de Entorno
# Copia este archivo a .env y completa los valores
# =============================================================================

# --- Base de Datos ---
# SQLite (dev): sqlite:///./sistema_legal.db
# PostgreSQL (prod): postgresql://user:password@host:5432/sistema_legal
DATABASE_URL=sqlite:///./sistema_legal.db

# --- LLM / IA ---
# Proveedor: ollama, openai, gemini, claude, openrouter
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# API Keys (solo si no usas Ollama)
# GEMINI_API_KEY=
# CLAUDE_API_KEY=
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=

# --- Autenticacion JWT ---
# IMPORTANTE! Cambia esto por una clave secreta segura en produccion.
# Genera una con: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=cambiar_en_produccion_por_clave_segura
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- RAG / Vector Store ---
CHROMA_PERSIST_DIRECTORY=./data/chroma
EMBEDDING_MODEL=mxbai-embed-large

# --- Rutas de Archivos ---
UPLOADS_DIR=./data/uploads
JURISPRUDENCE_DIR=./data/jurisprudence

# --- App ---
APP_NAME=Sistema Legal CO
DEBUG=false
LOG_LEVEL=info

# --- Rate Limiting ---
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_CHAT_PER_MINUTE=30
RATE_LIMIT_DEFAULT_PER_MINUTE=60
