# Sistema Legal CO - Configuración de Entorno
# Copia este archivo a .env y ajusta los valores

# === Base de datos ===
# SQLite (desarrollo)
DATABASE_URL=sqlite:///./sistema_legal.db
# PostgreSQL (producción)
# DATABASE_URL=postgresql://user:password@localhost:5432/sistema_legal

# === LLM Provider ===
# Opciones: ollama, gemini, claude, openai, openrouter
LLM_PROVIDER=ollama

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Gemini (Google)
# GEMINI_API_KEY=tu_api_key_aqui

# Claude (Anthropic)
# CLAUDE_API_KEY=tu_api_key_aqui

# OpenAI
# OPENAI_API_KEY=tu_api_key_aqui

# OpenRouter
# OPENROUTER_API_KEY=tu_api_key_aqui

# === Autenticación JWT ===
JWT_SECRET=cambiar_en_produccion_por_una_clave_segura
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# === RAG / Vector Store ===
CHROMA_PERSIST_DIRECTORY=./data/chroma
EMBEDDING_MODEL=mxbai-embed-large

# === Rutas de datos ===
UPLOADS_DIR=./data/uploads
JURISPRUDENCE_DIR=./data/jurisprudence

# === App ===
APP_NAME=Sistema Legal CO
DEBUG=true
